# Variables de entorno de AutoFacil (backend). Copie este archivo como `.env`
# y ajuste los valores. Todas las variables usan el prefijo AUTOFACIL_.

# Clave secreta para firmar los tokens JWT. OBLIGATORIO cambiarla por un valor
# largo y aleatorio fuera de un entorno de desarrollo local.
AUTOFACIL_CLAVE_SECRETA=cambie-esta-clave-por-un-valor-largo-y-aleatorio

# Algoritmo de firma JWT (por defecto HS256).
AUTOFACIL_ALGORITMO_JWT=HS256

# Minutos de validez del token de acceso (por defecto 480 = 8 horas).
AUTOFACIL_MINUTOS_EXPIRACION_TOKEN=480

# Dias de validez del enlace publico compartible con el cliente.
AUTOFACIL_DIAS_EXPIRACION_TOKEN_COMPARTIR=30

# Cadena de conexion a la base de datos (por defecto SQLite local).
# AUTOFACIL_URL_BASE_DATOS=sqlite:///./autofacil.db
